        "/api/dashboard": {
            "get": {
                "tags": [
                    "Tableau de bord"
                ],
                "summary": "Statistiques du tableau de bord",
                "description": "Retourne les compteurs globaux (articles, utilisateurs, commentaires) et les 5 derniers articles publiés avec leurs relations.",
                "operationId": "f9ae6bf029fd5455620e57be01c3b831",
                "responses": {
                    "200": {
                        "description": "Statistiques récupérées",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "stats": {
                                            "properties": {
                                                "total_articles": {
                                                    "type": "integer",
                                                    "example": 12
                                                },
                                                "total_users": {
                                                    "type": "integer",
                                                    "example": 5
                                                },
                                                "total_comments": {
                                                    "type": "integer",
                                                    "example": 23
                                                }
                                            },
                                            "type": "object"
                                        },
                                        "latest_articles": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/Article"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Non authentifié",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Unauthenticated."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
