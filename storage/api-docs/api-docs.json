                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Déconnexion réussie !"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Non authentifié",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Unauthenticated."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/comments": {
            "post": {
                "tags": [
                    "Commentaires"
                ],
                "summary": "Poster un commentaire",
                "description": "Ajoute un commentaire sur un article existant. Nécessite d'être authentifié.",
                "operationId": "300619a0a4003920aafe960e45688102",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "visitor_name",
                                    "visitor_email",
                                    "message",
                                    "article_id"
                                ],
                                "properties": {
                                    "visitor_name": {
                                        "description": "Nom du visiteur (max 191 caractères)",
                                        "type": "string",
                                        "example": "Jean Dupont"
                                    },
                                    "visitor_email": {
                                        "description": "Email du visiteur (max 191 caractères)",
                                        "type": "string",
                                        "format": "email",
                                        "example": "jean@exemple.fr"
                                    },
                                    "message": {
                                        "description": "Contenu du commentaire (max 1000 caractères)",
                                        "type": "string",
                                        "example": "Excellent article, très bien expliqué !"
                                    },
                                    "article_id": {
                                        "description": "ID de l'article auquel ce commentaire est rattaché",
                                        "type": "integer",
                                        "example": 1
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Commentaire publié",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Commentaire ajouté avec succès !"
                                        },
                                        "comment": {
                                            "$ref": "#/components/schemas/Comment"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Non authentifié",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Unauthenticated."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Erreur de validation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ValidationError"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
