    "components": {
        "schemas": {
            "User": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Sophie Marchand"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "admin@blogflow.fr"
                    },
                    "created_at": {
                        "type": "string",
